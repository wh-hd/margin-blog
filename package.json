{
  "name": "margin-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.22.2 <23"
  },
  "packageManager": "npm@10.9.7",
  "scripts": {
    "dev": "astro dev",
    "lint": "eslint . --max-warnings=0",
    "type-check": "astro check",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:contract": "npm run build",
    "test:watch": "vitest",
    "build": "astro build && node scripts/generate-redirects.mjs && node scripts/validate-build.mjs",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.1",
    "eslint": "10.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "wrangler": "4.111.0",
    "yaml": "2.9.0"
  }
}
