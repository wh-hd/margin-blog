---
interface TaxonomyLink { slug: string; name: string; }
interface Post {
  slug: string; href?: string; title: string; description: string; publishDate: string | Date; readingMinutes?: number; readingTimeLabel?: string;
  category: TaxonomyLink; tags?: TaxonomyLink[];
}
interface Props { post: Post; showCategory?: boolean; }
const { post, showCategory = true } = Astro.props;
const date = new Date(post.publishDate);
const dateText = new Intl.DateTimeFormat("zh-CN", { year: "numeric", month: "long", day: "numeric" }).format(date);
const reading = post.readingTimeLabel ?? `约 ${post.readingMinutes ?? 1} 分钟`;
const href = post.href ?? `/articles/${post.slug}/`;
---
<article class="article-row" data-article data-category={post.category.slug} data-tags={post.tags?.map((tag) => tag.slug).join(" ")}>
  <time datetime={date.toISOString()}>{dateText}</time>
  <div class="article-content">
    <h2><a href={href}>{post.title}</a></h2>
    <p>{post.description}</p>
    <div class="article-meta">
      <span>{reading}阅读</span>
      {showCategory && <a href={`/categories/${post.category.slug}/`}>{post.category.name}</a>}
      {post.tags?.map((tag) => <a href={`/tags/${tag.slug}/`}>#{tag.name}</a>)}
    </div>
  </div>
</article>
<style>
  .article-row { display: grid; grid-template-columns: 9rem minmax(0, 1fr); gap: var(--space-8); padding-block: var(--space-8); border-top: 1px solid var(--border-subtle); }
  time { padding-top: var(--space-1); color: var(--text-muted); font-size: var(--size-14); }
  h2 { margin: 0 0 var(--space-3); font-family: var(--font-display); font-size: var(--size-24); line-height: 1.25; }
  h2 a { text-decoration: none; text-underline-offset: .18em; transition: color var(--duration-fast) var(--ease-smooth); }
  h2 a:hover { color: var(--action-hover); text-decoration: underline; }
  p { max-width: 48rem; margin: 0 0 var(--space-4); color: var(--text-secondary); }
  .article-meta { display: flex; flex-wrap: wrap; gap: var(--space-2) var(--space-4); color: var(--text-muted); font-size: var(--size-14); }
  .article-meta a { color: var(--action-primary); text-underline-offset: .2em; }
  .article-meta a:hover { color: var(--action-hover); }
  @media (max-width: 63.99rem) { .article-row { grid-template-columns: 7rem minmax(0, 1fr); gap: var(--space-6); } }
  @media (max-width: 47.99rem) { .article-row { grid-template-columns: 1fr; gap: var(--space-2); padding-block: var(--space-6); } h2 { font-size: var(--size-20); } }
</style>
