---
interface Props { type: "category" | "tag"; name: string; description: string; count: number; }
const { type, name, description, count } = Astro.props;
const label = type === "category" ? "分类 / CATEGORY" : "标签 / TAG";
---
<header class="taxonomy-intro"><p class="eyebrow">{label}</p><h1>{type === "tag" ? `# ${name}` : name}</h1><p class="description">{description}</p><p class="count">共 {count} 篇文章</p></header>
<style>
  .taxonomy-intro { width: min(100%, var(--reading)); padding-block: var(--space-20) var(--space-10); }
  h1 { margin: 0 0 var(--space-4); font-family: var(--font-display); font-size: var(--size-40); line-height: 1.12; }
  .description { color: var(--text-secondary); font-size: var(--size-18); }
  .count { margin: var(--space-5) 0 0; color: var(--text-muted); font-size: var(--size-14); font-weight: 700; }
  @media (max-width: 47.99rem) { .taxonomy-intro { padding-block: var(--space-12) var(--space-8); } h1 { font-size: var(--size-32); } }
</style>
