---
import type { SiteSocialLink } from "../../lib/content/types";
interface Props { currentPath?: string; brand?: string; social?: SiteSocialLink[]; }
const { currentPath = Astro.url.pathname, brand = "wh", social = [] } = Astro.props;
const links = [
  { href: "/", label: "首页" },
  { href: "/articles/", label: "文章" },
  { href: "/archive/", label: "归档" },
  { href: "/categories/", label: "分类" },
  { href: "/says/", label: "说说" },
  { href: "/logs/", label: "日志" },
  { href: "/links/", label: "友链" },
  { href: "/about/", label: "关于" },
];
const isCurrent = (href: string) => href === "/" ? currentPath === "/" : currentPath.startsWith(href);
const externalLinks = social.map(({ label, url }) => ({ label, url, key: label.toLowerCase() }));
---
<header class="site-header">
  <a class="skip-link" href="#main-content">跳到正文</a>
  <div class="shell header-inner">
    <a class="brand-link" href="/" aria-label={`${brand} 首页`}>{brand}</a>
    <nav class="desktop-nav" aria-label="主导航">
      <ul>
        {links.map(({ href, label }) => <li><a href={href} aria-current={isCurrent(href) ? "page" : undefined}>{label}</a></li>)}
      </ul>
    </nav>
    <div class="header-actions">
      <ul class="external-links" aria-label="外部链接">
        {externalLinks.map(({ label, url, key }) => (
          <li>
            <a href={url} target="_blank" rel="noopener noreferrer" aria-label={label} title={label}>
              {key.includes("github") ? (
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"/></svg>
              ) : key.includes("twitter") || key.includes("x") ? (
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M18.2 2H21l-6.5 7.4L22 22h-6.8l-4.7-6.1L5.3 22H2.5l7-8L2 2h6.9l4.2 5.6L18.2 2Zm-2.4 18h1.9L8.3 4H6.3l9.5 16Z"/></svg>
              ) : (
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
              )}
            </a>
          </li>
        ))}
      </ul>
      <a class="admin-entry" href="/admin/" aria-label="内容管理后台">管理</a>
      <details class="mobile-nav">
        <summary><span class="menu-icon" aria-hidden="true">☰</span><span>菜单</span></summary>
        <nav aria-label="移动端主导航">
          <ul>{links.map(({ href, label }) => <li><a href={href} aria-current={isCurrent(href) ? "page" : undefined}>{label}</a></li>)}</ul>
          <ul class="mobile-external">{externalLinks.map(({ label, url }) => <li><a href={url} target="_blank" rel="noopener noreferrer">{label}</a></li>)}<li><a href="/admin/">管理后台</a></li></ul>
        </nav>
      </details>
    </div>
  </div>
</header>
<style>
  .site-header { position: sticky; z-index: 20; top: 0; height: var(--header-height); border-bottom: 1px solid var(--border-subtle); background: var(--bg-canvas); }
  .header-inner { display: flex; height: 100%; align-items: center; justify-content: space-between; gap: var(--space-4); }
  .brand-link { min-height: 2.75rem; display: inline-flex; align-items: center; font-family: var(--font-display); font-size: var(--size-20); font-weight: 700; text-decoration: none; }
  .desktop-nav ul, .mobile-nav ul { margin: 0; padding: 0; list-style: none; }
  .desktop-nav ul { display: flex; gap: var(--space-6); }
  .desktop-nav a, .mobile-nav a { position: relative; display: inline-flex; min-height: 2.75rem; align-items: center; color: var(--text-secondary); font-size: var(--size-14); font-weight: 650; text-decoration: none; transition: color var(--duration-fast) var(--ease-smooth); }
  .desktop-nav a::after { position: absolute; right: 0; bottom: 0; left: 0; height: 2px; background: var(--action-primary); content: ""; opacity: 0; transform: scaleX(.6); transition: opacity var(--duration-fast) var(--ease-smooth), transform var(--duration-fast) var(--ease-smooth); }
  .desktop-nav a:hover, .desktop-nav a[aria-current="page"], .mobile-nav a:hover, .mobile-nav a[aria-current="page"] { color: var(--action-hover); }
  .desktop-nav a[aria-current="page"]::after { opacity: 1; transform: scaleX(1); }
  .header-actions { display: flex; align-items: center; gap: var(--space-4); }
  .external-links { display: flex; align-items: center; gap: var(--space-3); }
  .external-links a { display: inline-flex; min-height: 2.75rem; align-items: center; color: var(--text-secondary); transition: color var(--duration-fast) var(--ease-smooth); }
  .external-links a:hover { color: var(--action-hover); }
  .admin-entry { display: inline-flex; min-height: 2.25rem; align-items: center; padding-inline: var(--space-3); border: 1px solid var(--border-default); border-radius: 999px; color: var(--text-secondary); font-size: var(--size-13); font-weight: 650; text-decoration: none; transition: border-color var(--duration-fast) var(--ease-smooth), color var(--duration-fast) var(--ease-smooth); }
  .admin-entry:hover { border-color: var(--action-primary); color: var(--action-hover); }
  .mobile-nav { display: none; }
  @media (max-width: 63.99rem) {
    .desktop-nav { display: none; }
    .header-actions { gap: var(--space-2); }
    .external-links { display: none; }
    .admin-entry { display: none; }
    .mobile-nav { display: block; }
    .mobile-nav summary { display: inline-flex; min-height: 2.75rem; align-items: center; gap: var(--space-2); color: var(--text-secondary); cursor: pointer; font-size: var(--size-14); font-weight: 700; list-style: none; }
    .menu-icon { font-size: var(--size-20); line-height: 1; }
    .mobile-nav summary::-webkit-details-marker { display: none; }
    .mobile-nav nav { position: absolute; top: var(--header-height); right: 0; left: 0; padding: var(--space-2) var(--space-4) var(--space-4); border-bottom: 1px solid var(--border-default); background: var(--bg-canvas); animation: reveal var(--duration-fast) var(--ease-smooth); }
    .mobile-nav a { width: 100%; min-height: 3rem; padding-inline: var(--space-2); border-bottom: 1px solid var(--border-subtle); }
    .mobile-nav a[aria-current="page"] { border-inline-start: 2px solid var(--action-primary); padding-inline-start: var(--space-3); }
    .mobile-external { margin-top: var(--space-2); padding-top: var(--space-2); border-top: 1px solid var(--border-subtle); }
  }
  @keyframes reveal { from { opacity: 0; } to { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .mobile-nav nav { animation: none; } }
</style>
