---
interface Props { currentPath?: string; brand?: string; }
const { currentPath = Astro.url.pathname, brand = "侧注 MARGIN" } = Astro.props;
const links = [
  { href: "/", label: "首页" },
  { href: "/articles/", label: "文章" },
  { href: "/categories/", label: "分类" },
  { href: "/about/", label: "关于" },
];
const isCurrent = (href: string) => href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---
<header class="site-header">
  <a class="skip-link" href="#main-content">跳到正文</a>
  <div class="shell header-inner">
    <a class="brand-link" href="/" aria-label={`${brand} 首页`}>{brand}</a>
    <nav class="desktop-nav" aria-label="主导航">
      <ul>
        {links.map(({ href, label }) => <li><a href={href} aria-current={isCurrent(href) ? "page" : undefined}>{label}</a></li>)}
      </ul>
    </nav>
    <details class="mobile-nav">
      <summary><span class="menu-icon" aria-hidden="true">☰</span><span>主导航</span></summary>
      <nav aria-label="移动端主导航">
        <ul>{links.map(({ href, label }) => <li><a href={href} aria-current={isCurrent(href) ? "page" : undefined}>{label}</a></li>)}</ul>
      </nav>
    </details>
  </div>
</header>
<style>
  .site-header { position: sticky; z-index: 20; top: 0; height: var(--header-height); border-bottom: 1px solid var(--border-subtle); background: var(--bg-canvas); }
  .header-inner { display: flex; height: 100%; align-items: center; justify-content: space-between; }
  .brand-link { min-height: 2.75rem; display: inline-flex; align-items: center; font-family: var(--font-display); font-size: var(--size-20); font-weight: 700; text-decoration: none; }
  .desktop-nav ul, .mobile-nav ul { margin: 0; padding: 0; list-style: none; }
  .desktop-nav ul { display: flex; gap: var(--space-6); }
  .desktop-nav a, .mobile-nav a { position: relative; display: inline-flex; min-height: 2.75rem; align-items: center; color: var(--text-secondary); font-size: var(--size-14); font-weight: 650; text-decoration: none; transition: color var(--duration-fast) var(--ease-smooth); }
  .desktop-nav a::after { position: absolute; right: 0; bottom: 0; left: 0; height: 2px; background: var(--action-primary); content: ""; opacity: 0; transform: scaleX(.6); transition: opacity var(--duration-fast) var(--ease-smooth), transform var(--duration-fast) var(--ease-smooth); }
  .desktop-nav a:hover, .desktop-nav a[aria-current="page"], .mobile-nav a:hover, .mobile-nav a[aria-current="page"] { color: var(--action-hover); }
  .desktop-nav a[aria-current="page"]::after { opacity: 1; transform: scaleX(1); }
  .mobile-nav { display: none; }
  @media (max-width: 47.99rem) {
    .desktop-nav { display: none; }
    .mobile-nav { display: block; }
    .mobile-nav summary { display: inline-flex; min-height: 2.75rem; align-items: center; gap: var(--space-2); color: var(--text-secondary); cursor: pointer; font-size: var(--size-14); font-weight: 700; list-style: none; }
    .menu-icon { font-size: var(--size-20); line-height: 1; }
    .mobile-nav summary::-webkit-details-marker { display: none; }
    .mobile-nav nav { position: absolute; top: var(--header-height); right: 0; left: 0; padding: var(--space-2) var(--space-4) var(--space-4); border-bottom: 1px solid var(--border-default); background: var(--bg-canvas); animation: reveal var(--duration-fast) var(--ease-smooth); }
    .mobile-nav a { width: 100%; min-height: 3rem; padding-inline: var(--space-2); border-bottom: 1px solid var(--border-subtle); }
    .mobile-nav a[aria-current="page"] { border-inline-start: 2px solid var(--action-primary); padding-inline-start: var(--space-3); }
  }
  @keyframes reveal { from { opacity: 0; } to { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .mobile-nav nav { animation: none; } }
</style>
