---
interface Heading { depth: number; slug: string; text: string; }
interface Props { headings: Heading[]; }
const { headings } = Astro.props;
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---
{items.length > 0 && <nav class="toc" data-toc aria-label="目录">
  <p class="toc-title">目录</p>
  <ul>
    {items.map((h) => <li class={`lvl-${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>)}
  </ul>
</nav>}

<style>
  .toc { font-family: var(--font-ui); }
  .toc-title { margin: 0 0 var(--space-3); color: var(--text-muted); font-size: var(--size-12); font-weight: 800; letter-spacing: .14em; text-transform: uppercase; }
  .toc ul { margin: 0; padding: 0; list-style: none; display: grid; gap: var(--space-2); border-inline-start: 2px solid var(--border-subtle); }
  .toc li { padding-inline-start: var(--space-3); }
  .toc li.lvl-3 { padding-inline-start: var(--space-6); }
  .toc a { display: block; color: var(--text-secondary); font-size: var(--size-14); line-height: 1.45; text-decoration: none; transition: color var(--duration-fast) var(--ease-smooth); }
  .toc a:hover { color: var(--action-hover); }
  .toc a[data-active="true"] { color: var(--action-primary); font-weight: 650; }
</style>
